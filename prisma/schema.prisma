// Prisma schema for GeoPulse

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Supabase "Session mode" for migrations
}

model User {
  id           String          @id @default(cuid())
  name         String
  email        String          @unique
  supabaseAuthId String?       @unique
  passwordHash String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  watchlists   Watchlist[]
  alerts       Alert[]
  preference   UserPreference?
  savedFilters SavedFilter[]
  digest       DigestSubscription?
  subscription Subscription?
  entitlements Entitlement[]
  deliveries   EmailDelivery[]
}

model UserPreference {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  categories String   @default("[]") // JSON array: ["energy","conflict","tech"]
  regions    String   @default("[]") // JSON array: ["Middle East","Europe"]
  symbols    String   @default("[]") // JSON array: ["SPY","NVDA","GLD"]
  onboarded  Boolean  @default(false)
  timezone   String   @default("UTC")
  digestHour Int      @default(7)
  emailDigestEnabled Boolean @default(true)
  deliveryChannels String @default("[\"email\"]")
  savedViewsEnabled Boolean @default(true)
  plan       String   @default("free")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Watchlist {
  id        String          @id @default(cuid())
  name      String
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  items     WatchlistItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model WatchlistItem {
  id          String      @id @default(cuid())
  symbol      String
  name        String
  assetClass  String
  countryCode String?
  watchlistId String
  watchlist   Watchlist   @relation(fields: [watchlistId], references: [id])
  createdAt   DateTime    @default(now())
}

model Event {
  id             String   @id @default(cuid())
  title          String
  summary        String
  source         String
  region         String
  countryCode    String?
  severity       Int
  sentimentScore Float?
  sentimentLabel String?
  publishedAt    DateTime
  url            String   @unique
  canonicalUrl   String?
  urlHash        String?
  feedGuid       String?
  firstSeenAt    DateTime @default(now())
  fetchedAt      DateTime?
  duplicateClusterId String?
  category       String   @default("general")
  tags           String   @default("[]")
  relevanceScore Float    @default(0)
  whyThisMatters String?
  supportingSourcesCount Int @default(1)
  sourceReliability Float @default(0.5)
  isPremiumInsight Boolean @default(false)
  createdAt      DateTime @default(now())
  correlations   Correlation[]

  @@index([publishedAt])
  @@index([region])
  @@index([severity])
  @@index([source])
  @@index([category])
  @@index([duplicateClusterId])
  @@index([urlHash])
}

model MarketSnapshot {
  id         String   @id @default(cuid())
  symbol     String
  price      Float
  changePct  Float
  assetClass String
  timestamp  DateTime
  provider   String   @default("snapshot")
  freshness  String   @default("snapshot")

  @@index([symbol, timestamp])
}

model Correlation {
  id              String   @id @default(cuid())
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id])
  symbol          String
  impactScore     Float
  impactDirection String   @default("neutral")
  impactMagnitude Float    @default(0)
  window          String
  category        String?
  createdAt       DateTime @default(now())

  @@index([eventId])
  @@index([symbol])
  @@index([impactDirection])
}

model Pattern {
  id            String   @id @default(cuid())
  eventCategory String
  symbol        String
  avgImpactPct  Float
  direction     String
  confidence    Float
  occurrences   Int
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([eventCategory, symbol])
}

model IngestionLog {
  id          String   @id @default(cuid())
  source      String
  eventsFound Int
  status      String
  error       String?
  startedAt   DateTime
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

model Alert {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  condition   String
  status      String
  createdAt   DateTime @default(now())
}

model SavedFilter {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  query       String?
  regions     String   @default("[]")
  categories  String   @default("[]")
  symbols     String   @default("[]")
  direction   String   @default("all")
  severityMin Int      @default(0)
  timeWindow  String   @default("all")
  sortKey     String   @default("relevance")
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
}

model DigestSubscription {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  enabled          Boolean  @default(true)
  digestHour       Int      @default(7)
  timezone         String   @default("UTC")
  deliveryChannels String   @default("[\"email\"]")
  topStories       Int      @default(5)
  lastSentAt       DateTime?
  deliveries       EmailDelivery[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Subscription {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id])
  provider               String   @default("stripe")
  customerId             String?  @unique
  providerSubscriptionId String?  @unique
  status                 String   @default("beta")
  plan                   String   @default("free")
  billingInterval        String   @default("monthly")
  currentPeriodEnd       DateTime?
  trialEnd               DateTime? // Free trial period end date
  cancelAtPeriodEnd      Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Entitlement {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  key       String
  enabled   Boolean  @default(true)
  source    String   @default("beta")
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
}

model EmailDelivery {
  id                   String              @id @default(cuid())
  userId               String
  user                 User                @relation(fields: [userId], references: [id])
  digestSubscriptionId String?
  digestSubscription   DigestSubscription? @relation(fields: [digestSubscriptionId], references: [id])
  type                 String
  status               String
  provider             String?
  messageId            String?
  dedupeKey            String?             @unique
  payload              String?
  sentAt               DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([userId, createdAt])
}

model IngestionJob {
  id             String   @id @default(cuid())
  kind           String
  stage          String?
  status         String
  source         String?
  attempts       Int      @default(0)
  itemsProcessed Int      @default(0)
  error          String?
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([kind, status, createdAt])
}

model SourceHealth {
  id             String   @id @default(cuid())
  source         String
  feedUrl        String
  status         String   @default("unknown")
  lastFetchedAt  DateTime?
  lastSucceededAt DateTime?
  lastError      String?
  lastLatencyMs  Int?
  failureCount   Int      @default(0)
  successCount   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([source, feedUrl])
}

model ApiRateLimit {
  namespace  String
  identifier String
  count      Int      @default(0)
  resetAt    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([namespace, identifier])
  @@index([resetAt])
}
